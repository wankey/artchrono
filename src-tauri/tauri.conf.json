{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "艺时纪",
  "version": "0.1.0",
  "identifier": "com.wankey.artchrono",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "艺时纪",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "记录每一刻艺术时光",
    "longDescription": "艺时纪 — 独立艺术老师的课程管家。排课、考勤、续费，一纪了然。"
  }
}