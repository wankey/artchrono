# Supabase 配置
# 复制到 .env.local 并填入真实值
# .env.local 已在 .gitignore 中，不会被 commit

# 公开端点 + anon key（前端 + Tauri 用，公开安全）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key（仅 GitHub Actions cron 用，绕过 RLS）
# ⚠️ 绝对不能放进 Tauri bundle 或 commit 进 git
# 只在 .env.local（开发）和 GitHub Actions secrets（生产）出现
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here